<IfModule mod_autoindex.c>
    IndexIgnore *
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Gzip compression for CSS files
    RewriteCond %{HTTP:Accept-Encoding} \b(gzip|deflate)\b
    RewriteCond %{REQUEST_FILENAME}\.gz -s
    RewriteRule ^(.*)\.css$ $1\.css\.gz [QSA]

    # Gzip compression for JS files
    RewriteCond %{HTTP:Accept-Encoding} \b(gzip|deflate)\b
    RewriteCond %{REQUEST_FILENAME}\.gz -s
    RewriteRule ^(.*)\.js$ $1\.js\.gz [QSA]

    # Disable gzip for already compressed files
    RewriteRule \.css\.gz$ - [T=text/css,E=no-gzip:1]
    RewriteRule \.js\.gz$ - [T=text/javascript,E=no-gzip:1]
</IfModule>

<FilesMatch "(\.js\.gz|\.css\.gz)$">
    Header set Content-Encoding gzip
    Header append Vary Accept-Encoding
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirect www to non-www and exclude robots.txt
    RewriteCond %{HTTP_HOST} ^www\.bitcryptogazette\.com$ [NC]
    RewriteCond %{REQUEST_URI} !^/robots\.txt$ [NC]
    RewriteRule ^(.*)$ https://bitcryptogazette.com/$1 [L,R=301]
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Deny access to www subdomain
    RewriteCond %{HTTP_HOST} ^www\.bitcryptogazette\.com$ [NC]
    RewriteRule ^ - [F]

    # Block malicious queries
    RewriteCond %{QUERY_STRING} base64_encode[^(]*\([^)]*\) [OR]
    RewriteCond %{QUERY_STRING} (<|%3C)([^s]*s)+cript.*(>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2})
    RewriteRule .* index.php [F]
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Set HTTP_AUTHORIZATION header
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Rewrite API requests
    RewriteCond %{REQUEST_URI} ^/api/
    RewriteCond %{REQUEST_URI} !^/api/index\.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule .* api/index.php [L]

    # Rewrite other requests to index.php
    RewriteCond %{REQUEST_URI} !^/index\.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule .* index.php [L]
</IfModule>
